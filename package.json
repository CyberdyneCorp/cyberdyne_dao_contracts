{
  "name": "@cyberdyne/dao-contracts",
  "version": "0.9.0-rc1",
  "description": "Cyberdyne DAO — Aragon OSx plugins for Uniswap V4 swaps, AAVE lending, and monthly payroll.",
  "license": "AGPL-3.0-or-later",
  "main": "./index.mjs",
  "module": "./index.mjs",
  "exports": {
    ".": {
      "default": "./index.mjs"
    },
    "./addresses": "./addresses.json",
    "./abis/*": "./frontend-abi/*.json"
  },
  "files": [
    "index.mjs",
    "addresses.json",
    "frontend-abi/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyberdyneCorp/cyberdyne_dao_contracts.git"
  },
  "scripts": {
    "build": "hardhat compile",
    "build:abi": "node scripts/export-abis.js",
    "build:addresses": "node scripts/build-addresses.js",
    "build:package": "npm run build && npm run build:abi && npm run build:addresses",
    "prepublishOnly": "npm run build:package",
    "test": "hardhat test",
    "test:unit": "hardhat test --grep '^(?!.*\\[fork\\])'",
    "test:fork:mainnet": "hardhat test --network mainnetFork",
    "test:fork:base": "hardhat test --network baseFork",
    "coverage": "hardhat coverage",
    "node:mainnet": "hardhat node --fork ${RPC_MAINNET}",
    "node:base": "hardhat node --fork ${RPC_BASE}",
    "lint:sol": "solhint 'src/**/*.sol' 'test/**/*.sol'",
    "lint:ts": "eslint 'test/**/*.ts' 'scripts/**/*.ts'",
    "format": "prettier --write 'src/**/*.sol' 'test/**/*.ts' '*.{json,md,yml}'",
    "format:check": "prettier --check 'src/**/*.sol' 'test/**/*.ts' '*.{json,md,yml}'",
    "typechain": "hardhat typechain",
    "clean": "hardhat clean && rm -rf out cache cache_hardhat artifacts typechain-types coverage"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.6",
    "@nomicfoundation/hardhat-foundry": "^1.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^2.0.2",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@nomiclabs/hardhat-etherscan": "^3.1.8",
    "@typechain/ethers-v5": "^10.1.0",
    "@typechain/hardhat": "^6.1.6",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-plugin-mocha": "^10.5.0",
    "ethers": "^5.7.2",
    "hardhat": "^2.22.10",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.3.3",
    "prettier-plugin-solidity": "^1.4.1",
    "solhint": "^5.0.3",
    "solidity-coverage": "^0.8.13",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
