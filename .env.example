# RPC endpoints for fork tests + live deployments.
# Use Alchemy / Infura archive nodes — block pinning needs historical state.
RPC_MAINNET=
RPC_BASE=
RPC_SEPOLIA=
RPC_BASE_SEPOLIA=
RPC_POLYGON=
RPC_ARBITRUM=
RPC_OPTIMISM=

# Block pinning for CI determinism (leave unset for local dev = freshest state).
PIN_MAINNET=
PIN_BASE=

# Deployer key (use a burner; drain after deploy ceremony per TRD §15).
DEPLOYER_KEY=

# Block-explorer API keys (for contract verification).
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Gas reporting (optional).
GAS_REPORT=false
