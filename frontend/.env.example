# WalletConnect v2 project ID. Get one at https://cloud.walletconnect.com/
# Used by @walletconnect/ethereum-provider — required for WC v2 connections;
# injected (MetaMask) fallback still works without it.
PUBLIC_WC_PROJECT_ID=

# Default RPC URLs per chain (optional — wallet provides its own RPC after
# connect, these are used for read-only views BEFORE the user connects).
PUBLIC_RPC_MAINNET=https://eth.llamarpc.com
PUBLIC_RPC_BASE=https://mainnet.base.org
PUBLIC_RPC_SEPOLIA=https://rpc.sepolia.org
PUBLIC_RPC_BASE_SEPOLIA=https://sepolia.base.org

# Optional Graph subgraph endpoint. When set, history views (swaps, cost
# payments, V3 positions) query the subgraph for full/fast history instead of
# paging back N blocks via direct RPC. Leave blank to use the RPC-scan
# fallback (works on a bare localFork with no subgraph deployed).
# Deploy the subgraph from subgraph/ — see subgraph/README.md.
PUBLIC_SUBGRAPH_URL=

# Optional Uniswap official subgraphs (The Graph decentralized network). When
# set, the Pools cards on the positions page show whole-pool market stats —
# fee APR, 1D/30D volume, pool TVL, and a 30-day volume sparkline — keyed by
# V3 pool address / V4 poolId. These index REAL mainnet, which is valid on a
# mainnet fork (pools mirror mainnet); the DAO's fork-local positions still
# come from RPC. Leave blank to hide the market columns.
# Format: https://gateway.thegraph.com/api/<API_KEY>/subgraphs/id/<SUBGRAPH_ID>
# Get a free API key at https://thegraph.com/studio/ . Mainnet subgraph IDs:
#   V3: 5zvR82QoaXYFyDEKLZ9t6v9adgnptxYpKpSbxtgVENFV
#   V4: DiYPVdygkfjDWhbxGSqAQxwBKmfKnkWQojqeM2rkLb3G
PUBLIC_UNISWAP_V3_SUBGRAPH_URL=
PUBLIC_UNISWAP_V4_SUBGRAPH_URL=

# Optional Pinata JWT for IPFS proposal-metadata pinning. When set, creating a
# proposal pins a structured metadata JSON (schema cyberdyne-proposal/1) and
# stores the resulting ipfs://CID as the proposal's on-chain metadata. Leave
# blank to store the summary string inline as UTF-8 (toy-frontend default).
# Get a JWT at https://app.pinata.cloud/ (scope: pinJSONToIPFS).
PUBLIC_PINATA_JWT=

# Per-DAO deployment addresses. Hand-maintained from
# deployments/<chain>-<timestamp>.json produced by `just deploy-local` / `just deploy`.
# Format: PUBLIC_DAO_<CHAIN>=<dao>,<payroll>,<uniswap>,<aave>[,<governance>[,<costRegistry>[,<uniswapV3>]]]
#   - <governance> is the TokenVoting plugin instance (optional 5th field).
#     With it, the Proposals page can create proposals + vote/execute.
#     Without it, the UI only emits calldata JSON for an external builder.
#   - <costRegistry> is the CostRegistry plugin instance (optional 6th field)
#     for the recurring operating-costs page.
#   - <uniswapV3> is the UniswapV3Plugin instance (optional 7th field) for the
#     Uniswap V3 LP positions page.
# Leave blank to fall back to the connect-wallet prompt for an ad-hoc DAO.
PUBLIC_DAO_MAINNET=
PUBLIC_DAO_BASE=
PUBLIC_DAO_SEPOLIA=
PUBLIC_DAO_BASE_SEPOLIA=
