# WalletConnect v2 project ID. Get one at https://cloud.walletconnect.com/
# Used by @walletconnect/ethereum-provider — required for WC v2 connections;
# injected (MetaMask) fallback still works without it.
PUBLIC_WC_PROJECT_ID=

# Default RPC URLs per chain (optional — wallet provides its own RPC after
# connect, these are used for read-only views BEFORE the user connects).
PUBLIC_RPC_MAINNET=https://eth.llamarpc.com
PUBLIC_RPC_BASE=https://mainnet.base.org
PUBLIC_RPC_SEPOLIA=https://rpc.sepolia.org
PUBLIC_RPC_BASE_SEPOLIA=https://sepolia.base.org

# Per-DAO deployment addresses. Hand-maintained from
# deployments/<chain>-<timestamp>.json produced by `just deploy-cyberdyne-dao`.
# Format: PUBLIC_DAO_<CHAIN>=<dao>,<payroll>,<uniswap>,<aave>
# Leave blank to fall back to the connect-wallet prompt for an ad-hoc DAO.
PUBLIC_DAO_MAINNET=
PUBLIC_DAO_BASE=
PUBLIC_DAO_SEPOLIA=
PUBLIC_DAO_BASE_SEPOLIA=
